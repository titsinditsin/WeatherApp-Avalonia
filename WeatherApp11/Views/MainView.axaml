<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:WeatherApp11.ViewModels"
             x:Class="WeatherApp11.Views.MainView"
             x:DataType="vm:MainViewModel">

    <UserControl.Styles>
        <Style Selector="Button.update">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#F5F0E8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="0,16"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.update:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#333333"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#F5F0E8">
        <Border Width="340"
                CornerRadius="4"
                Padding="32,36"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="0">

                <!-- Верхняя строка: город -->
                <TextBlock Text="МОСКВА"
                           FontSize="11"
                           Foreground="#999999"
                           LetterSpacing="3"
                           Margin="0,0,0,40"/>

                <!-- Температура + иконка -->
                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="{Binding TempDisplay}"
                               FontSize="100"
                               FontWeight="Bold"
                               Foreground="#1A1A1A"
                               LineHeight="100"
                               VerticalAlignment="Bottom"/>

                    <Image Grid.Column="1"
                           Source="{Binding WeatherIcon}"
                           Width="52"
                           Height="52"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,12"/>
                </Grid>

                <!-- Описание -->
                <TextBlock Text="{Binding WeatherDisplay}"
                           FontSize="13"
                           Foreground="#999999"
                           LetterSpacing="1"
                           Margin="0,0,0,4"/>

                <!-- Ощущается как -->
                <TextBlock Text="{Binding FeelsLikeDisplay}"
                           FontSize="12"
                           Foreground="#BBBBBB"
                           Margin="0,0,0,36"/>

                <!-- Разделитель -->
                <Border Height="1"
                        Background="#D8D2C8"
                        Margin="0,0,0,28"/>

                <!-- Кнопка -->
                <Button Classes="update"
                        Command="{Binding GetWeatherCommand}"
                        Content="ОБНОВИТЬ"
                        HorizontalAlignment="Stretch"/>

            </StackPanel>
        </Border>
    </Grid>

</UserControl>